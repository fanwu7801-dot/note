        </mxCell>
        <mxCell id="hal" value="&lt;b&gt;HAL / GPIO / Timer / RTOS&lt;/b&gt;&lt;br&gt;具体平台实现&lt;br&gt;替换 MCU 或 BSP 时只改这一层" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;fontSize=15;" vertex="1" parent="1">
